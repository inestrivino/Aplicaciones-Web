<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Mis Reservas</title>
  <meta name="description"
    content="EcoMóvil es una empresa de vehículos eléctricos disponibles para prestamo. Esta página permite a nuestros empleados gestionar nuestra flota." />
  <meta name="keywords"
    content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil, soluciones de transporte, movilidad verde" />
  <meta name="author" content="EcoMóvil" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="img/Logo.svg" type="image/x-icon" />

  <!-- Enlaces a las hojas de estilo -->
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="css/styles.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>
  <!-- NAVBAR -->
  <%- include('partials/header', { user: user, concesionarios: concesionarios }) %>

    <main aria-label="Contenido principal">
      <h1>Mis Reservas de Vehículos</h1>

      <!-- Contenedor para las reservas -->
      <div class="reservation-list row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="reservationList">
        <% if (reservas && reservas.length> 0) { %>
          <% reservas.forEach(r=> { %>
            <div class="col">
              <div class="card h-100">
                <img src="<%= r.vehiculo_imagen %>" class="card-img-top img-fluid" alt="<%= r.vehiculo_modelo %>"
                  style="height: 200px; object-fit: cover;">
                <div class="card-body">
                  <h5 class="card-title">
                    <%= r.vehiculo_modelo %>
                  </h5>
                  <h6>
                    <%= r.fecha_ini.toLocaleDateString('es-ES') %> - <%= r.fecha_fin.toLocaleDateString('es-ES') %>
                  </h6>
                  <ul class="list-unstyled">
                    <li><strong>Matrícula:</strong>
                      <%= r.matricula %>
                    </li>
                    <li><strong>Concesionario:</strong>
                      <%= r.vehiculo_concesionario %>
                    </li>
                    <li><strong>Estado:</strong>
                      <%= r.estado %>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
            <% }) %>
              <% } else { %>
                <p>No tienes reservas de vehículos en este momento.</p>
                <% } %>
      </div>

    </main>

    <!-- FOOTER -->
    <%- include("partials/footer") %>

      <!-- Script de Bootstrap -->
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
      <script src="/js/client.js"></script>
</body>

</html>