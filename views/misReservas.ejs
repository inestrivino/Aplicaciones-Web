<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Mis Reservas</title>
  <meta name="description"
    content="EcoMóvil es una empresa de vehículos eléctricos disponibles para prestamo. Esta página permite a nuestros empleados gestionar nuestra flota." />
  <meta name="keywords"
    content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil, soluciones de transporte, movilidad verde" />
  <meta name="author" content="EcoMóvil" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="img/Logo.svg" type="image/x-icon" />

  <!-- Enlaces a las hojas de estilo -->
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="css/styles.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>
  <!-- NAVBAR -->
  <%- include('partials/header', { user: user, concesionarios: concesionarios }) %>
    <main aria-label="Contenido principal">
      <h1>Mis Reservas de Vehículos</h1>

      <% if (typeof errorMessage !=='undefined' ) { %>
        <div class="alert alert-danger" role="alert">
          <%= errorMessage %>
        </div>
        <% } %>
          <% if (typeof responseMessage !=='undefined' ) { %>
            <div class="alert alert-success" role="alert">
              <%= responseMessage %>
            </div>
            <% } %>

              <ul class="nav nav-tabs" id="reservasTabs" role="tablist">
                <li class="nav-item" role="presentation">
                  <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#curso" type="button">
                    En curso
                  </button>
                </li>
                <li class="nav-item" role="presentation">
                  <button class="nav-link" data-bs-toggle="tab" data-bs-target="#proximas" type="button">
                    Próximas
                  </button>
                </li>
                <li class="nav-item" role="presentation">
                  <button class="nav-link" data-bs-toggle="tab" data-bs-target="#pasadas" type="button">
                    Pasadas
                  </button>
                </li>

              </ul>
              <div class="tab-content mt-4">

                <!-- EN CURSO -->
                <div class="tab-pane fade show active" id="curso">

                  <% if (enCurso && enCurso.length> 0) { %>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                      <% enCurso.forEach(r=> { %>
                        <div class="modal fade" id="modalFeedback<%= r.id %>" tabindex="-1">
                          <div class="modal-dialog">
                            <div class="modal-content">

                              <div class="modal-header">
                                <h5 class="modal-title">Devolver vehículo</h5>
                              </div>

                              <form action="/misReservas/devolver/<%= r.id %>" method="POST">

                                <div class="modal-body">

                                  <label>Puntuación:</label>
                                  <select name="puntuacion" class="form-select mb-3">
                                    <option value="">Sin valoración</option>
                                    <option value="1">⭐</option>
                                    <option value="2">⭐⭐</option>
                                    <option value="3">⭐⭐⭐</option>
                                    <option value="4">⭐⭐⭐⭐</option>
                                    <option value="5">⭐⭐⭐⭐⭐</option>
                                  </select>

                                  <label>Comentario:</label>
                                  <textarea name="comentario" class="form-control" placeholder="Opcional"></textarea>

                                </div>

                                <div class="modal-footer">
                                  <!-- SOLO devolver -->
                                  <button type="submit" name="accion" value="solo" class="btn btn-warning">
                                    Devolver sin valorar
                                  </button>

                                  <!-- devolver + feedback -->
                                  <button type="submit" name="accion" value="feedback" class="btn btn-success">
                                    Enviar con valoración
                                  </button>

                                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                    Cancelar
                                  </button>
                                </div>

                              </form>

                            </div>
                          </div>
                        </div>
                        <div class="col">
                          <div class="card h-100">
                            <img src="<%= r.vehiculo_imagen %>" class="card-img-top img-fluid"
                              alt="<%= r.vehiculo_modelo %>" style="height: 200px; object-fit: cover;">

                            <div class="card-body">
                              <h5 class="card-title">
                                <%= r.vehiculo_modelo %>
                              </h5>

                              <h6>
                                <%= r.fecha_ini.toLocaleDateString('es-ES') %> -
                                  <%= r.fecha_fin.toLocaleDateString('es-ES') %>
                              </h6>

                              <ul class="list-unstyled">
                                <li><strong>Matrícula:</strong>
                                  <%= r.matricula %>
                                </li>
                                <li><strong>Concesionario:</strong>
                                  <%= r.concesionario_nombre %>
                                </li>
                              </ul>
                            </div>

                            <button type="button" class="btn btn-warning w-100" data-bs-toggle="modal"
                              data-bs-target="#modalFeedback<%= r.id %>">
                              Devolver vehículo
                            </button>

                          </div>
                        </div>
                        <% }) %>
                    </div>
                    <% } else { %>
                      <div class="alert alert-info">
                        No tienes reservas en curso actualmente.
                      </div>
                      <% } %>

                </div>

                <!-- PRÓXIMAS -->
                <div class="tab-pane fade" id="proximas">

                  <% if (proximas && proximas.length> 0) { %>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                      <% proximas.forEach(r=> { %>
                        <div class="col">
                          <div class="card h-100">
                            <img src="<%= r.vehiculo_imagen %>" class="card-img-top img-fluid"
                              alt="<%= r.vehiculo_modelo %>" style="height: 200px; object-fit: cover;">

                            <div class="card-body">
                              <h5 class="card-title">
                                <%= r.vehiculo_modelo %>
                              </h5>

                              <h6>
                                <%= r.fecha_ini.toLocaleDateString('es-ES') %> -
                                  <%= r.fecha_fin.toLocaleDateString('es-ES') %>
                              </h6>

                              <ul class="list-unstyled">
                                <li><strong>Matrícula:</strong>
                                  <%= r.matricula %>
                                </li>
                                <li><strong>Concesionario:</strong>
                                  <%= r.concesionario_nombre %>
                                </li>
                              </ul>
                              <form action="/misReservas/cancelar/<%= r.id %>" method="POST"
                                onsubmit="return confirm('¿Seguro que quieres cancelar esta reserva?');">
                                <button class="btn btn-danger w-100">
                                  Cancelar reserva
                                </button>
                              </form>
                            </div>
                          </div>
                        </div>
                        <% }) %>
                    </div>
                    <% } else { %>
                      <div class="alert alert-info">
                        No tienes reservas próximas.
                      </div>
                      <% } %>

                </div>

                <!-- PASADAS -->
                <div class="tab-pane fade" id="pasadas">

                  <% if (pasadas && pasadas.length> 0) { %>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                      <% pasadas.forEach(r=> { %>
                        <div class="col">
                          <div class="card h-100">
                            <img src="<%= r.vehiculo_imagen %>" class="card-img-top img-fluid"
                              alt="<%= r.vehiculo_modelo %>" style="height: 200px; object-fit: cover;">

                            <div class="card-body">
                              <h5 class="card-title">
                                <%= r.vehiculo_modelo %>
                              </h5>

                              <h6>
                                <%= r.fecha_ini.toLocaleDateString('es-ES') %> -
                                  <%= r.fecha_fin.toLocaleDateString('es-ES') %>
                              </h6>

                              <ul class="list-unstyled">
                                <li><strong>Matrícula:</strong>
                                  <%= r.matricula %>
                                </li>
                                <li><strong>Concesionario:</strong>
                                  <%= r.concesionario_nombre %>
                                </li>

                                <% if (r.puntuacion) { %>
                                  <p>
                                    <strong>Valoración:</strong>
                                    <%= "⭐" .repeat(r.puntuacion) %>
                                  </p>

                                  <% if (r.comentario) { %>
                                    <p><strong>Comentario:</strong>
                                      <%= r.comentario %>
                                    </p>
                                    <% } %>
                                      <% } else { %>
                                        <p class="text-muted">Sin valoración</p>
                                        <% } %>
                              </ul>
                            </div>

                          </div>
                        </div>
                        <% }) %>
                    </div>
                    <% } else { %>
                      <div class="alert alert-secondary">
                        No tienes reservas pasadas.
                      </div>
                      <% } %>

                </div>

              </div>
    </main>

    <!-- FOOTER -->
    <%- include("partials/footer") %>

      <!-- Script de Bootstrap -->
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
      <script src="/js/client.js"></script>
</body>

</html>