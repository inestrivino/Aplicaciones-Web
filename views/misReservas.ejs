<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Mis Reservas</title>
  <meta name="description"
    content="EcoMóvil es una empresa de vehículos eléctricos disponibles para prestamo. Esta página permite a nuestros empleados gestionar nuestra flota." />
  <meta name="keywords"
    content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil, soluciones de transporte, movilidad verde" />
  <meta name="author" content="EcoMóvil" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="/img/Logo.svg" type="image/x-icon" />

  <!-- Enlaces a las hojas de estilo -->
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>
  <!-- NAVBAR -->
  <%- include('partials/header', { user: user }) %>
    <main aria-label="Contenido principal">
      <h1>Mis Reservas de Vehículos</h1>

      <div id="feedback-container"></div>

      <ul class="nav nav-tabs" id="reservasTabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#curso" type="button">
            En curso
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" data-bs-toggle="tab" data-bs-target="#proximas" type="button">
            Próximas
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" data-bs-toggle="tab" data-bs-target="#pasadas" type="button">
            Pasadas
          </button>
        </li>
      </ul>

      <div id="modales">
        <div class="modal fade" id="devolucionModal" tabindex="-1">
          <div class="modal-dialog">
            <div class="modal-content">

              <div class="modal-header">
                <h5 class="modal-title">Devolver vehículo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>

              <div class="modal-body">

                <label>Puntuación (opcional)</label>
                <select id="puntuacion" class="form-select mb-3">
                  <option value="">Sin valoración</option>
                  <option value="5">⭐⭐⭐⭐⭐</option>
                  <option value="4">⭐⭐⭐⭐</option>
                  <option value="3">⭐⭐⭐</option>
                  <option value="2">⭐⭐</option>
                  <option value="1">⭐</option>
                </select>

                <textarea id="comentario" class="form-control" placeholder="Comentario opcional..."></textarea>

                <div class="mb-3">
                  <label for="kilometros" class="form-label">Kilómetros recorridos</label>
                  <input type="number" id="kilometros" class="form-control" min="0" placeholder="Ej: 120" required />
                </div>

              </div>

              <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-warning" id="confirmarDevolucionBtn">Devolver vehículo</button>
              </div>

            </div>
          </div>
        </div>
        <div class="modal fade" id="incidenciaModal" tabindex="-1">
          <div class="modal-dialog">
            <div class="modal-content">

              <div class="modal-header">
                <h5 class="modal-title">Reportar incidencia</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>

              <div class="modal-body">
                <textarea id="incidenciaTexto" class="form-control" placeholder="Describe la incidencia..."></textarea>
                <small id="incidenciaError" class="text-danger d-none">Debes escribir un comentario</small>
              </div>

              <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-danger" id="confirmarIncidenciaBtn">Enviar</button>
              </div>

            </div>
          </div>
        </div>
      </div>
      <div class="tab-content mt-4">

        <!-- EN CURSO -->
        <div class="tab-pane fade show active" id="curso">
          <div id="curso-container"></div>
        </div>

        <!-- PRÓXIMAS -->
        <div class="tab-pane fade" id="proximas">
          <div id="proximas-container"></div>
        </div>

        <!-- PASADAS -->
        <div class="tab-pane fade" id="pasadas">
          <div id="pasadas-container"></div>
        </div>

      </div>
    </main>

    <!-- FOOTER -->
    <%- include("partials/footer") %>
</body>

</html>