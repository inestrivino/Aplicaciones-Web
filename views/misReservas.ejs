<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Mis Reservas</title>
  <meta name="description"
    content="EcoMóvil es una empresa de vehículos eléctricos disponibles para prestamo. Esta página permite a nuestros empleados gestionar nuestra flota." />
  <meta name="keywords"
    content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil, soluciones de transporte, movilidad verde" />
  <meta name="author" content="EcoMóvil" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="img/Logo.svg" type="image/x-icon" />

  <!-- Enlaces a las hojas de estilo -->
   <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="css/styles.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>
  <!-- NAVBAR -->
  <%- include('partials/header', { user: user, concesionarios: concesionarios }) %>

    <main aria-label="Contenido principal">
      <h1>Mis Reservas de Vehículos</h1>

      <!-- Contenedor para las reservas -->
      <div class="reservation-list ow row-cols-1 row-cols-lg-3 g-4" id="reservationList">
        <% if (reservas && reservas.length> 0) { %>
          <% for (let i=0; i < reservas.length; i++) { %>
            <div class="col">
              <div class="card h-100">
                <img src="<%= reservas[i].vehiculo.imagen %>" class="card-img-top img-fluid"
                  alt="<%= reservas[i].vehiculo.nombre %>" style="height: 200px; object-fit: cover;">
                <div class="card-body">
                  <h5 class="card-title">
                    <%= reservas[i].vehiculo.nombre %>
                  </h5>
                  <h6>
                    <%= reservas[i].fechaIni %> - <%= reservas[i].fechaFin %>
                  </h6>
                  <!-- Detalles del vehículo -->
                  <ul class="list-unstyled">
                    <li><strong>Matrícula:</strong>
                      <%= reservas[i].vehiculo.matricula %>
                    </li>
                    <li><strong>Autonomía:</strong>
                      <%= reservas[i].vehiculo.autonomia %> km
                    </li>
                    <li><strong>Plazas:</strong>
                      <%= reservas[i].vehiculo.plazas %>
                    </li>
                    <li><strong>Concesionario:</strong>
                      <%= reservas[i].vehiculo.concesionario %>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
            <% } %>
              <% } else { %>
                <p>No tienes reservas de vehículos en este momento.</p>
                <% } %>
      </div>
    </main>

    <!-- FOOTER -->
    <%- include("partials/footer") %>

      <!-- Script de Bootstrap -->
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
      <script src="/js/client.js"></script>
</body>

</html>