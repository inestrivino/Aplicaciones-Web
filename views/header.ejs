<!-- MODAL DE AJUSTES -->
<div class="modal fade" id="ajustesModal" tabindex="-1" aria-labelledby="ajustesModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="ajustesModalLabel">Ajustes</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>

      <div class="modal-body">

        <!-- Sección: Idioma -->
        <section>
          <h6>Idioma</h6>
          <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="dropdownIdioma"
              data-bs-toggle="dropdown" aria-expanded="false">
              <span id="idiomaSeleccionado">Español</span>
            </button>
            <ul class="dropdown-menu" aria-labelledby="dropdownIdioma">
              <li><a class="dropdown-item" href="#" data-lang="es">Español</a></li>
              <li><a class="dropdown-item" href="#" data-lang="en">English</a></li>
            </ul>
          </div>
        </section>

        <!-- Sección: Tema -->
        <section>
          <h6>Tema visual</h6>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="tema" id="temaClaro" value="claro" checked>
            <label class="form-check-label" for="temaClaro">Claro</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="tema" id="temaOscuro" value="oscuro">
            <label class="form-check-label" for="temaOscuro">Oscuro</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="tema" id="temaAltoContraste" value="alto-contraste">
            <label class="form-check-label" for="temaAltoContraste">Alto contraste</label>
          </div>
        </section>

        <!-- Sección: Tamaño de letra -->
        <section>
          <h6>Tamaño de letra</h6>
          <label for="fontSizeRange" class="form-label small text-muted">
            Selecciona el tamaño del texto
          </label>
          <input type="range" class="form-range" id="fontSizeRange" min="1" max="1.4" step="0.05" value="1.2">
          <p>Tamaño actual: <span id="fontSizeValue">1.2rem</span></p>
        </section>

        <!-- Sección: Configuración de Atajos de Teclado -->
        <section>
          <h6>Atajos de Teclado</h6>
          <div class="mb-3">
            <label for="shortcutInicio" class="form-label">Inicio (Alt + )</label>
            <input type="text" class="form-control" id="shortcutInicio" value="i">
          </div>
          <div class="mb-3">
            <label for="shortcutContacto" class="form-label">Contacto (Alt + )</label>
            <input type="text" class="form-control" id="shortcutContacto" value="c">
          </div>
          <% if (user) { %>
          <div class="mb-3">
            <label for="shortcutVehiculos" class="form-label">Vehículos (Alt + )</label>
            <input type="text" class="form-control" id="shortcutVehiculos" value="v">
          </div>
          <div class="mb-3">
            <label for="shortcutReservar" class="form-label">Reservar (Alt + )</label>
            <input type="text" class="form-control" id="shortcutReservar" value="r">
          </div>
          <div class="mb-3">
            <label for="shortcutMisReservas" class="form-label">Mis Reservas (Alt + )</label>
            <input type="text" class="form-control" id="shortcutMisReservas" value="m">
          </div>
          <div class="mb-3">
            <label for="shortcutPanel" class="form-label">Panel (Alt + )</label>
            <input type="text" class="form-control" id="shortcutContacto" value="p">
          </div>
          <% } %>
        </section>

      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" id="guardarCambios">Guardar cambios</button>
      </div>
    </div>
  </div>
</div>


<!-- MODAL DE USUARIO -->
<div class="modal fade" id="usuarioModal" tabindex="-1" aria-labelledby="usuarioModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="usuarioModalLabel">Mi cuenta</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <% if (user) { %>
          <p> Bienvenido <%= user %>
          </p>
          <% } else { %>
            <!-- Formulario inicio de sesión-->
            <div id="signInForm" class="auth-form">
              <form action="/user/login" method="POST">
                <div>
                  <label for="signInEmail" class="form-label">Correo electrónico</label>
                  <input type="email" class="form-control" name="signInEmail" id="signInEmail"
                    placeholder="Correo electrónico" required>
                </div>
                <div>
                  <label for="signInPassword" class="form-label">Contraseña</label>
                  <input type="password" class="form-control" name="signInPassword" id="signInPassword"
                    placeholder="Contraseña" required>
                </div>
                <button type="submit" class="btn btn-primary w-100">Iniciar sesión</button>
              </form>
              <p>¿Aún no tienes cuenta? <button class="btn btn-link" id="signUpBtn">Registrarse</button></p>
            </div>

            <!-- Formulario de registro -->
            <div id="signUpForm" class="auth-form" style="display: none;" onsubmit="return validateEmailSignUp()">
              <form action="/user/register" method="POST">
                <div>
                  <label for="signUpName" class="form-label">Nombre completo</label>
                  <input type="text" class="form-control" name="signUpName" id="signUpName"
                    placeholder="Nombre completo" required maxlength="15">
                </div>
                <div>
                  <label for="signUpEmail" class="form-label">Correo electrónico</label>
                  <input type="email" class="form-control" name="signUpEmail" id="signUpEmail"
                    placeholder="Correo electrónico" required maxlength="100">
                  <div id="signUpEmailError" class="text-danger" style="display: none;">El correo electrónico debe
                    terminar en @ucm.</div>
                </div>
                <div>
                  <label for="signUpPassword" class="form-label">Contraseña</label>
                  <input type="password" class="form-control" name="signUpPassword" id="signUpPassword"
                    placeholder="Contraseña" minlength="8" maxlength="30" required>
                  <div class="invalid-feedback">
                    La contraseña debe tener al menos 8 caracteres.
                  </div>
                </div>
                <div>
                  <label for="signUpConfirmPassword" class="form-label">Confirmar contraseña</label>
                  <input type="password" class="form-control" name="signUpConfirmPassword" id="signUpConfirmPassword"
                    placeholder="Confirmar contraseña">
                </div>
                <button type="submit" class="btn btn-primary w-100">Registrarse</button>
              </form>
              <p>¿Ya tienes cuenta? <button class="btn btn-link" id="signInBtn">Iniciar sesión</button></p>
            </div>
            <% } %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
        <% if (user) { %>
          <a href="/user/logout" class="btn btn-danger">
            Cerrar Sesión
          </a>
          <% } %>
      </div>
    </div>
  </div>
</div>