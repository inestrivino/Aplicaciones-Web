<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Reservar con EcoMóvil</title>
  <meta name="description"
    content="EcoMóvil es una empresa de vehículos eléctricos disponibles para prestamo. Esta página permite a nuestros empleados gestionar nuestra flota." />
  <meta name="keywords"
    content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil, soluciones de transporte, movilidad verde" />
  <meta name="author" content="EcoMóvil" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="/img/Logo.svg" type="image/x-icon" />

  <!-- Enlaces a las hojas de estilo -->
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
</head>

<body>
  <!-- NAVBAR -->
  <%- include('partials/header', { user: user }) %>

    <main aria-label="Contenido principal de la página">
      <h1>Reservar vehículos</h1>

      <div id="feedback-container"></div>

      <form id="reservaForm" aria-label="Formulario de reserva de vehículos">

        <fieldset aria-label="Detalles de la reserva">
          <legend>Detalles de la reserva</legend>

          <div>
            <label for="vehiculo" class="form-label">Vehículo</label>
            <select class="form-select" id="vehiculo" name="matricula" required>
              <option value="">Cargando vehículos...</option>
            </select>
          </div>

          <div>
            <label for="inicioFecha" class="form-label">Inicio de reserva</label>
            <input type="text" class="form-control" name="fecha_ini" id="inicioFecha" required
              aria-label="Seleccionar fecha de inicio" />
          </div>

          <div>
            <label for="finFecha" class="form-label">Fin de reserva</label>
            <input type="text" class="form-control" name="fecha_fin" id="finFecha" required
              aria-label="Seleccionar fecha de fin" />
          </div>

        </fieldset>

        <div class="form-check mt-3">
          <input type="checkbox" class="form-check-input" name="condiciones" id="condiciones" required />
          <label class="form-check-label" for="condiciones">
            Acepto las condiciones de uso
          </label>
        </div>

        <div class="mt-3">
          <button type="submit" class="btn btn-primary" aria-label="Enviar formulario de reserva">
            Enviar reserva
          </button>

          <button type="reset" class="btn btn-secondary" aria-label="Limpiar formulario de reserva">
            Limpiar formulario
          </button>
        </div>

      </form>
    </main>

    <!-- FOOTER -->
    <%- include("partials/footer") %>

</body>

</html>