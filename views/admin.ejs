<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Admin</title>
  <meta name="description"
    content="EcoMóvil es una empresa de vehículos eléctricos disponibles para prestamo. Esta página permite a nuestros empleados gestionar nuestra flota." />
  <meta name="keywords"
    content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil, soluciones de transporte, movilidad verde" />
  <meta name="author" content="EcoMóvil" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="img/Logo.svg" type="image/x-icon" />

  <!-- Enlaces a las hojas de estilo -->
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>
  <!-- NAVBAR -->
  <%- include('header', { user: user }) %>
  <main class="card" role="main">
    <h1>Panel de gestión</h1><br>
    <h3>Insercción en la base de datos mediante JSON</h3>
    <div>
      <form id="jsonForm" action="/admin/rellenar" method="POST" enctype="multipart/form-data">
        <input type="file" id="file" name="file" accept=".json"><br><br>
        <button type="submit">Enviar JSON</button><br>
      </form>
    </div>
    <br>
    
    
    <style>
    .tres-columnas {
      display: flex;
      gap: 20px;
    }
    .tres-columnas > div {
      flex: 1; /* que todas las columnas ocupen el mismo ancho */
    }
    </style>

    <!-- Concesionarios -->
    <% if (vehiculos) { %>
    <h4>Resultados de la insercción de concesionarios:</h4>
    <div class="tres-columnas">
      <% if (insertadosCon.length !== 0) { %>
      <div>
        <strong>Insertados</strong> <br>
        <% for (nombre of insertadosCon) { %>
          <%=nombre%> <br>
        <% } %>
      </div>
      <% } %>
      <% if (erroresCon.length !== 0) { %>
      <div>
        <strong>Errores</strong> <br>
        <% for (nombre of erroresCon) { %>
          <%=nombre%> <br>
        <% } %>
      </div>
      <% } %>
    </div>
    <br><br>
    <% } %>

    <!-- Vehiculos -->
    <% if (vehiculos) { %>
    <h4>Resultados de la insercción de vehículos:</h4>
    <div class="tres-columnas">
      <% if (VehiculosInsertados.length !== 0) { %>
      <div>
        <strong>Insertados</strong> <br>
        <% for (matricula of VehiculosInsertados) { %>
          <%=matricula%> <br>
        <% } %>
      </div>
      <% } %>
      <% if (VehiculosPendientes.length !== 0) { %>
      <div>
        <strong>Pendientes</strong> <br>
        <% for (matricula of VehiculosPendientes) { %>
          <%=matricula%> <br>
        <% } %>
        <br>
        <form action="/admin/modificarPendientes" method="POST">
          <button type="submit">Confirmar</button>
        </form>
      </div>
      <% } %>
      <% if (VehiculosErrores.length !== 0) { %>
      <div>
        <strong>Errores</strong> <br>
        <% for (matricula of VehiculosErrores) { %>
          <%=matricula%> <br>
        <% } %>
      </div>
      <% } %>
    </div>
    <br><br>
    <% } %>

    <h3>Acciones de administrador</h3>
    <div class="grid" role="list">
      <button class="btn" id="vehiculos" role="listitem" aria-label="Gestión de vehículos">• Gestión de
        vehículos</button>
      <button class="btn secondary" id="concesionarios" role="listitem" aria-label="Gestión de concesionarios">•
        Gestión de concesionarios</button>
      <button class="btn" id="usuarios" role="listitem" aria-label="Gestión de usuarios">• Gestión de
        usuarios</button>
      <button class="btn secondary" id="estadisticas" role="listitem" aria-label="Estadísticas">•
        Estadísticas</button>
    </div>
  </main>

  <!-- FOOTER -->
  <%- include("footer") %>

</body>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/client.js"></script>

</html>