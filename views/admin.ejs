<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Admin</title>
  <meta name="description"
    content="EcoMóvil es una empresa de vehículos eléctricos disponibles para prestamo. Esta página permite a nuestros empleados gestionar nuestra flota." />
  <meta name="keywords"
    content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil, soluciones de transporte, movilidad verde" />
  <meta name="author" content="EcoMóvil" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="img/Logo.svg" type="image/x-icon" />

  <!-- Enlaces a las hojas de estilo -->
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>
  <!-- NAVBAR -->
  <%- include('partials/header', { user: user }) %>

  <main class="container mt-5" role="main">
    <h1>Panel de gestión</h1><br>
    <fieldset>
      <h2>Insercción en la base de datos mediante JSON</h2>
      <form id="jsonForm" action="/admin/rellenar" method="POST" enctype="multipart/form-data">
        <input class="form-control-lg" type="file" id="file" name="file" accept=".json"><br>
        <button class="btn btn-primary mt-3" type="submit">Enviar JSON</button><br>
      </form>

      <style>
      .tres-columnas {
        display: flex;
        gap: 20px;
      }
      .tres-columnas > div {
        flex: 1; /* que todas las columnas ocupen el mismo ancho */
      }
      </style>

      <!-- Concesionarios -->
      <% if (vehiculosList) { %>
      <h2 class="mt-3">Resultados de la insercción de concesionarios:</h2>
      <div class="tres-columnas">
        <% if (insertadosCon.length !== 0) { %>
        <div>
          <strong>Insertados</strong> <br>
          <% for (nombre of insertadosCon) { %>
            <%=nombre%> <br>
          <% } %>
        </div>
        <% } %>
        <% if (erroresCon.length !== 0) { %>
        <div>
          <strong>Errores</strong> <br>
          <% for (nombre of erroresCon) { %>
            <%=nombre%> <br>
          <% } %>
        </div>
        <% } %>
      </div>
      <% } %>

      <!-- Vehiculos -->
      <% if (vehiculosList) { %>
      <h2 class="mt-3">Resultados de la insercción de vehículos:</h2>
      <div class="tres-columnas">
        <% if (VehiculosInsertados.length !== 0) { %>
        <div>
          <strong>Insertados</strong> <br>
          <% for (matricula of VehiculosInsertados) { %>
            <%=matricula%> <br>
          <% } %>
        </div>
        <% } %>
        <% if (VehiculosPendientes.length !== 0) { %>
        <div>
          <strong>Pendientes</strong> <br>
          <% for (matricula of VehiculosPendientes) { %>
            <%=matricula%> <br>
          <% } %>
          <br>
          <form action="/admin/modificarPendientes" method="POST">
            <button class="btn btn-secondary" type="submit">Confirmar</button>
          </form>
        </div>
        <% } %>
        <% if (VehiculosErrores.length !== 0) { %>
        <div>
          <strong>Errores</strong> <br>
          <% for (matricula of VehiculosErrores) { %>
            <%=matricula%> <br>
          <% } %>
        </div>
        <% } %>
      </div>
      <% } %>
    </fieldset>
    
    <fieldset class="grid" role="list">
      <h3> Acciones de administrador</h3><br>
      <a href="#altaVehiculo" class="btn btn-light" aria-label="Gestión de vehículos">
        • Alta de vehículo
      </a>
      <a href="#gestionVehiculos" class="btn btn-light" aria-label="Gestión de vehículos">
        • Gestión de vehículos
      </a>
      <a class="btn btn-light" id="concesionarios" role="listitem" aria-label="Gestión de concesionarios">
        • Gestión de concesionarios
      </a>
      <a class="btn btn-light" id="usuarios" role="listitem" aria-label="Gestión de usuarios">
        • Gestión de usuarios
      </a>
      <a class="btn btn-light" id="estadisticas" role="listitem" aria-label="Estadísticas">
        • Estadísticas
      </a>
    </fieldset>

    <form action="/vehiculos/create" method="POST" id="altaVehiculo">
      <fieldset class="grid" role="list">
        <h3> Alta de vehiculo</h3>
        <div class="d-flex align-items-center gap-2">
          <strong>Matricula:</strong>
          <input class="form-control" type="text" name="matricula" required>
        </div>
        <div class="d-flex align-items-center gap-2">
          <strong>Marca:</strong>
          <input class="form-control" type="text" name="marca" required>
        </div>
        <div class="d-flex align-items-center gap-2">
          <strong>Modelo:</strong>
          <input class="form-control" type="text" name="modelo" required>
        </div>
        <div class="d-flex align-items-center gap-2">
          <strong>fecha:</strong>
          <input type="datetime-local" class="form-control" name="fecha" id="inicioFecha" aria-required="true" required
          aria-label="Seleccionar fecha y hora de inicio"/>
        </div>
        <div class="d-flex align-items-center gap-2">
          <strong>Plazas:</strong>
          <input class="form-control" type="text" name="plazas" required>
        </div>
        <div class="d-flex align-items-center gap-2">
          <strong>Autonomía:</strong>
          <input class="form-control" type="text" name="autonomia" required> 
        </div>
        <div class="d-flex align-items-center gap-2">
          <strong>Color:</strong>
          <input class="form-control" type="text" name="color" required>
        </div>
        <div class="d-flex align-items-center gap-2">
          <strong>Imagen URL:</strong>
          <input class="form-control" type="text" name="imagen" required>
        </div>
        <div class="d-flex align-items-center gap-2">
          <strong>Estado:</strong>
          <input class="form-control" type="text" name="estado" required>
        </div>
        <div class="d-flex align-items-center gap-2">
          <strong >Concesionario:</strong>
          <input class="form-control" type="text" name="id_concesionario" required>
        </div>
        <button class="btn btn-primary mt-3" type="submit">Enviar JSON</button>
      </fieldset>
    </form>

    <!-- Lista de vehiculos -->
    <h1 class="mt-5" id="gestionVehiculos">Gestión de vehiculos</h1>
    <div class="container" aria-label="Contenido principal de la página">
      <div class="row row-cols-1 row-cols-lg-3 g-4">
        <% for (let i=0; i < vehiculos.length; i++) { %>
          <div class="col">
            <div class="card h-100">
              <img src="<%= vehiculos[i].imagen %>" class="card-img-top img-fluid"
                  alt="<%= vehiculos[i].nombre %>" style="height: 200px; object-fit: cover;">
              <div class="card-body">
                <h5 class="card-title">
                    <%= vehiculos[i].nombre %>
                </h5>
                <!-- Detalles del vehículo -->
                <form class="list-unstyled" action="/vehiculos/<%= vehiculos[i].matricula %>/update" method="POST" id="formVehiculo_<%= vehiculos[i].matricula %>">
                  <div class="d-flex align-items-center gap-2">
                    <strong>Matrícula:</strong>
                    <%= vehiculos[i].matricula %>
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <strong>Marca:</strong>
                    <input class="form-control" type="text" name="marca" value="<%= vehiculos[i].marca %>">
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <strong>Modelo:</strong>
                    <input class="form-control" type="text" name="modelo" value="<%= vehiculos[i].modelo %>">
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <strong>fecha:</strong>
                    <input type="datetime-local" class="form-control" name="fecha" id="inicioFecha" aria-required="true" required
                    aria-label="Seleccionar fecha y hora de inicio" value="<%= vehiculos[i].fecha.toISOString().slice(0,16) %>"/>
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <strong>Plazas:</strong>
                    <input class="form-control" type="text" name="plazas" value="<%= vehiculos[i].plazas %>">
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <strong>Autonomía:</strong>
                    <input class="form-control" type="text" name="autonomia" value="<%= vehiculos[i].autonomia %>"> 
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <strong>Color:</strong>
                    <input class="form-control" type="text" name="color" value="<%= vehiculos[i].color %>">
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <strong>Imagen URL:</strong>
                    <input class="form-control" type="text" name="imagen" value="<%= vehiculos[i].imagen %>">
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <strong>Estado:</strong>
                    <input class="form-control" type="text" name="estado" value="<%= vehiculos[i].plazas %>">
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <strong >Concesionario:</strong>
                    <input class="form-control" type="text" name="id_concesionario" value="<%= vehiculos[i].id_concesionario %>">
                  </div>
                </form>
                <div class="d-flex justify-content-center mt-3">
                  <button class="btn btn-secondary" form="formVehiculo_<%= vehiculos[i].matricula %>">
                    Modificar
                  </button>
                  <form action="/vehiculos/<%= vehiculos[i].matricula %>/delete" method="POST" class="ms-2">
                      <button type="submit" class="btn btn-danger">
                          Eliminar
                      </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </main>

  <!-- FOOTER -->
  <%- include("partials/footer") %>

</body>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/client.js"></script>

</html>