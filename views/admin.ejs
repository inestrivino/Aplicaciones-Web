<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin</title>
  <meta name="description" content="EcoMóvil es una empresa de vehículos eléctricos disponibles para préstamo." />
  <meta name="keywords" content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil" />
  <meta name="author" content="EcoMóvil" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" href="/img/Logo.svg" type="image/x-icon" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/styles.css" />
</head>

<body>
  <%- include('partials/header', { user: user, concesionarios: concesionarios }) %>

    <main class="container" role="main">
      <h1>Panel de gestión</h1>

      <% if (typeof errorMessage !=='undefined' ) { %>
        <div class="alert alert-danger" role="alert">
          <%= errorMessage %>
        </div>
        <% } %>
          <% if (typeof responseMessage !=='undefined' ) { %>
            <div class="alert alert-success" role="alert">
              <%= responseMessage %>
            </div>
            <% } %>

              <ul class="nav nav-tabs mb-3" id="myTab" role="tablist">
                <li class="nav-item" role="presentation">
                  <button class="nav-link active" id="baseDatos-tab" data-bs-toggle="tab" data-bs-target="#baseDatos"
                    type="button" role="tab">Base de datos</button>
                </li>
                <li class="nav-item" role="presentation">
                  <button class="nav-link" id="concesionarios-tab" data-bs-toggle="tab" data-bs-target="#concesionarios"
                    type="button" role="tab">Concesionarios</button>
                </li>
                <li class="nav-item" role="presentation">
                  <button class="nav-link" id="vehiculos-tab" data-bs-toggle="tab" data-bs-target="#vehiculos"
                    type="button" role="tab">Vehículos</button>
                </li>
                <li class="nav-item" role="presentation">
                  <button class="nav-link" id="usuarios-tab" data-bs-toggle="tab" data-bs-target="#usuarios"
                    type="button" role="tab">Usuarios</button>
                </li>
                <li class="nav-item" role="presentation">
                  <button class="nav-link" id="estadisticas-tab" data-bs-toggle="tab" data-bs-target="#estadisticas"
                    type="button" role="tab">Estadísticas</button>
                </li>
              </ul>

              <div class="tab-content" id="myTabContent">
                <div class="tab-pane fade show active" id="baseDatos" role="tabpanel" style="overflow-x: scroll;">
                  <fieldset>
                    <h2>Inserción en la base de datos mediante JSON</h2>
                    <form id="jsonForm" action="/admin/rellenar" method="POST" enctype="multipart/form-data">
                      <input class="form-control-lg" type="file" id="file" name="file" accept=".json" required><br>
                      <button class="btn btn-primary mt-3" type="submit">Enviar JSON</button><br>
                    </form>

                    <% if (vehiculosList) { %>
                      <h2 class="mt-3">Resultados de la inserción de concesionarios:</h2>
                      <div>
                        <% if (insertadosCon.length !==0) { %>
                          <div>
                            <strong>Insertados</strong> <br>
                            <% for (nombre of insertadosCon) { %>
                              <%=nombre%> <br>
                                <% } %>
                          </div>
                          <% } %>
                            <% if (erroresCon.length !==0) { %>
                              <div>
                                <strong>Errores</strong> <br>
                                <% for (nombre of erroresCon) { %>
                                  <%=nombre%> <br>
                                    <% } %>
                              </div>
                              <% } %>
                      </div>

                      <h2 class="mt-3">Resultados de la inserción de vehículos:</h2>
                      <div>
                        <% if (VehiculosInsertados.length !==0) { %>
                          <div>
                            <strong>Insertados</strong> <br>
                            <% for (matricula of VehiculosInsertados) { %>
                              <%=matricula%> <br>
                                <% } %>
                          </div>
                          <% } %>
                            <% if (VehiculosErrores.length !==0) { %>
                              <div>
                                <strong>Errores</strong> <br>
                                <% for (matricula of VehiculosErrores) { %>
                                  <%=matricula%> <br>
                                    <% } %>
                              </div>
                              <% } %>
                      </div>
                      <% } %>
                  </fieldset>
                </div>

                <div class="tab-pane fade" id="concesionarios" role="tabpanel">
                  <div class="card mb-4">
                    <div class="card-header bg-primary d-flex justify-content-between align-items-center"
                      style="cursor: pointer; color:white" data-bs-toggle="collapse"
                      data-bs-target="#collapseAltaConcesionario" aria-expanded="false">
                      <h5 class="mb-0">Alta de concesionario</h5>
                      <i class="bi bi-chevron-down"></i>
                    </div>

                    <div class="collapse" id="collapseAltaConcesionario">
                      <div class="card-body">
                        <form action="/concesionarios/create" method="POST" id="altaConcesionario">
                          <div class="mb-3">
                            <label for="nombre" class="form-label"><strong>Nombre:</strong></label>
                            <input type="text" class="form-control" id="nombre" name="nombre" required>
                          </div>
                          <div class="mb-3">
                            <label for="ciudad" class="form-label"><strong>Ciudad:</strong></label>
                            <input type="text" class="form-control" id="ciudad" name="ciudad" required>
                          </div>
                          <div class="mb-3">
                            <label for="direccion" class="form-label"><strong>Dirección:</strong></label>
                            <input type="text" class="form-control" id="direccion" name="direccion" required>
                          </div>
                          <div class="mb-3">
                            <label for="telefono" class="form-label"><strong>Teléfono:</strong></label>
                            <input type="text" class="form-control" id="telefono" name="telefono" required>
                          </div>
                          <button type="submit" class="btn btn-primary">Enviar</button>
                        </form>
                      </div>
                    </div>
                  </div>

                  <div class="table-responsive" style="max-height: 600px; overflow-y:auto;">
                    <table class="table table-sm table-striped table-bordered align-middle">
                      <thead class="table-dark sticky-top">
                        <tr>
                          <th>ID</th>
                          <th class="d-sm-table-cell">Nombre</th>
                          <th class="d-sm-table-cell">Ciudad</th>
                          <th class="d-md-table-cell">Dirección</th>
                          <th class="d-md-table-cell">Teléfono</th>
                          <th>Acciones</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% for (let i=0; i < concesionarios.length; i++) { %>
                          <tr>
                            <td>
                              <%= concesionarios[i].id %>
                            </td>
                            <td class="d-sm-table-cell">
                              <input class="form-control form-control-sm" type="text" name="nombre"
                                value="<%= concesionarios[i].nombre %>" form="form<%= concesionarios[i].id %>">
                            </td>
                            <td class="d-sm-table-cell">
                              <input class="form-control form-control-sm" type="text" name="ciudad"
                                value="<%= concesionarios[i].ciudad %>" form="form<%= concesionarios[i].id %>">
                            </td>
                            <td class="d-md-table-cell">
                              <input class="form-control form-control-sm" type="text" name="direccion"
                                value="<%= concesionarios[i].direccion %>" form="form<%= concesionarios[i].id %>">
                            </td>
                            <td class="d-md-table-cell">
                              <input class="form-control form-control-sm" type="text" name="telefono"
                                value="<%= concesionarios[i].telefono %>" form="form<%= concesionarios[i].id %>">
                            </td>
                            <td>
                              <form id="form<%= concesionarios[i].id %>"
                                action="/concesionarios/<%= concesionarios[i].id %>/update" method="POST"></form>

                              <button class="btn btn-sm btn-secondary mb-1"
                                form="form<%= concesionarios[i].id %>">Modificar</button>
                              <form action="/concesionarios/<%= concesionarios[i].id %>/delete" method="POST"
                                onsubmit="return confirm('¿Estás seguro de que quieres eliminar este concesionario?');"
                                style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                              </form>
                            </td>
                          </tr>
                          <% } %>
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="tab-pane fade" id="vehiculos" role="tabpanel">
                  <div class="card mb-4">
                    <div class="card-header bg-primary d-flex justify-content-between align-items-center"
                      style="cursor: pointer; color: white;" data-bs-toggle="collapse"
                      data-bs-target="#collapseAltaVehiculo" aria-expanded="false">
                      <h5 class="mb-0">Alta de vehículo</h5>
                      <i class="bi bi-chevron-down"></i>
                    </div>

                    <div class="collapse" id="collapseAltaVehiculo">
                      <div class="card-body">
                        <form action="/vehiculos/create" method="POST" id="altaVehiculo">

                          <div class="mb-3">
                            <label for="matricula" class="form-label"><strong>Matrícula:</strong></label>
                            <input type="text" class="form-control" id="matricula" name="matricula"
                              pattern="^\d{4}[A-Z]{3}$" title="Debe tener 4 números y 3 letras mayúsculas, ej: 1234ABC"
                              required>
                          </div>

                          <div class="mb-3">
                            <label for="marca" class="form-label"><strong>Marca:</strong></label>
                            <input type="text" class="form-control" id="marca" name="marca" required>
                          </div>

                          <div class="mb-3">
                            <label for="modelo" class="form-label"><strong>Modelo:</strong></label>
                            <input type="text" class="form-control" id="modelo" name="modelo" required>
                          </div>

                          <div class="mb-3">
                            <label for="plazas" class="form-label"><strong>Plazas:</strong></label>
                            <input type="number" class="form-control" id="plazas" name="plazas" min="1" required>
                          </div>

                          <div class="mb-3">
                            <label for="autonomia" class="form-label"><strong>Autonomía:</strong></label>
                            <input type="number" class="form-control" id="autonomia" name="autonomia" min="1" required>
                          </div>

                          <div class="mb-3">
                            <label for="color" class="form-label"><strong>Color:</strong></label>
                            <input type="text" class="form-control" id="color" name="color" required>
                          </div>

                          <div class="mb-3">
                            <label for="imagen" class="form-label"><strong>Imagen:</strong></label>
                            <select class="form-select" name="imagen" id="imagen" required>
                              <% imagenesVehiculos.forEach(img=> { %>
                                <option value="<%= img %>">
                                  <%= img %>
                                </option>
                                <% }) %>
                            </select>
                          </div>

                          <div class="mb-3">
                            <label for="id_concesionario" class="form-label"><strong>Concesionario:</strong></label>
                            <select class="form-select" id="id_concesionario" name="id_concesionario" required>
                              <% concesionarios.forEach(c=> { %>
                                <option value="<%= c.id %>">
                                  <%= c.nombre %> (<%= c.ciudad %>)
                                </option>
                                <% }) %>
                            </select>
                          </div>

                          <button type="submit" class="btn btn-primary">Enviar</button>
                        </form>
                      </div>
                    </div>
                  </div>

                  <div class="table-responsive" style="max-height: 600px; overflow-y:auto;">
                    <table class="table table-sm table-striped table-bordered align-middle">
                      <thead class="table-dark sticky-top">
                        <tr>
                          <th>Matrícula</th>
                          <th>Marca</th>
                          <th>Modelo</th>
                          <th>Fecha</th>
                          <th>Plazas</th>
                          <th>Autonomía</th>
                          <th>Color</th>
                          <th>Concesionario</th>
                          <th>Imagen</th>
                          <th>Acciones</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% for (let i=0; i < vehiculos.length; i++) { %>
                          <tr>
                            <td>
                              <%= vehiculos[i].matricula %>
                            </td>
                            <td>
                              <input class="form-control form-control-sm" type="text" name="marca"
                                value="<%= vehiculos[i].marca %>" form="form<%= vehiculos[i].matricula %>">
                            </td>
                            <td>
                              <input class="form-control form-control-sm" type="text" name="modelo"
                                value="<%= vehiculos[i].modelo %>" form="form<%= vehiculos[i].matricula %>">
                            </td>
                            <td>
                              <input class="form-control form-control-sm" type="date" name="fecha"
                                value="<%= vehiculos[i].fecha%>" form="form<%= vehiculos[i].matricula %>">
                            </td>
                            <td>
                              <input class="form-control form-control-sm" type="number" name="plazas"
                                value="<%= vehiculos[i].plazas %>" form="form<%= vehiculos[i].matricula %>">
                            </td>
                            <td>
                              <input class="form-control form-control-sm" type="number" name="autonomia"
                                value="<%= vehiculos[i].autonomia %>" form="form<%= vehiculos[i].matricula %>">
                            </td>
                            <td>
                              <input class="form-control form-control-sm" type="text" name="color"
                                value="<%= vehiculos[i].color %>" form="form<%= vehiculos[i].matricula %>">
                            </td>
                            <td>
                              <select class="form-select form-select-sm" name="id_concesionario"
                                form="form<%= vehiculos[i].matricula %>">
                                <% concesionarios.forEach(c=> { %>
                                  <option value="<%= c.id %>" <%=c.id===vehiculos[i].id_concesionario ? 'selected' : ''
                                    %>>
                                    <%= c.nombre %> (<%= c.ciudad %>)
                                  </option>
                                  <% }) %>
                              </select>
                            </td>
                            <td>
                              <select class="form-select form-select-sm" name="imagen"
                                form="form<%= vehiculos[i].matricula %>">
                                <% imagenesVehiculos.forEach(img=> { %>
                                  <% const imagenBD=vehiculos[i].imagen.split('/').pop().trim(); %>
                                    <option value="<%= img %>" <%=imagenBD===img.trim() ? 'selected' : '' %>>
                                      <%= img %>
                                    </option>
                                    <% }) %>
                              </select>
                            </td>
                            <td>
                              <form id="form<%= vehiculos[i].matricula %>"
                                action="/vehiculos/<%= vehiculos[i].matricula %>/update" method="POST"></form>

                              <button class="btn btn-sm btn-secondary mb-1"
                                form="form<%= vehiculos[i].matricula %>">Modificar</button>
                              <form action="/vehiculos/<%= vehiculos[i].matricula %>/delete" method="POST"
                                onsubmit="return confirm('¿Estás seguro de que quieres eliminar este vehículo?');"
                                style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                              </form>
                            </td>
                          </tr>
                          <% } %>
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="tab-pane fade" id="usuarios" role="tabpanel">
                  <div class="table-responsive" style="max-height: 600px; overflow-y:auto;">
                    <table class="table table-sm table-striped table-bordered align-middle">
                      <thead class="table-dark sticky-top">
                        <tr>
                          <th>ID</th>
                          <th class="d-sm-table-cell">Nombre</th>
                          <th class="d-sm-table-cell">Correo</th>
                          <th class="d-md-table-cell">Rol</th>
                          <th class="d-lg-table-cell">Concesionario</th>
                          <th>Acciones</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% for (let i=0; i < usuarios.length; i++) { %>
                          <tr>
                            <td>
                              <%= usuarios[i].id %>
                            </td>
                            <td class="d-sm-table-cell">
                              <input class="form-control form-control-sm" type="text" name="name"
                                value="<%= usuarios[i].name %>" form="formUsuarios_<%= usuarios[i].id %>">
                            </td>
                            <td class="d-sm-table-cell">
                              <input class="form-control form-control-sm" type="text" name="email"
                                value="<%= usuarios[i].email %>" form="formUsuarios_<%= usuarios[i].id %>">
                            </td>
                            <td class="d-md-table-cell">
                              <select class="form-select form-select-sm" name="rol"
                                form="formUsuarios_<%= usuarios[i].id %>">
                                <option value="admin" <%=usuarios[i].rol==='admin' ? 'selected' : '' %>>admin</option>
                                <option value="user" <%=usuarios[i].rol==='user' ? 'selected' : '' %>>user</option>
                              </select>
                            </td>
                            <td>
                              <select class="form-select form-select-sm" name="id_concesionario"
                                form="formUsuarios_<%= usuarios[i].id %>">
                                <% concesionarios.forEach(c=> { %>
                                  <option value="<%= c.id %>" <%=c.id===usuarios[i].id_concesionario ? 'selected' : ''
                                    %>>
                                    <%= c.nombre %> (<%= c.ciudad %>)
                                  </option>
                                  <% }) %>
                              </select>
                            </td>
                            <td>
                              <form id="formUsuarios_<%= usuarios[i].id %>" action="/user/<%= usuarios[i].id %>/update"
                                method="POST"></form>

                              <button class="btn btn-sm btn-secondary mb-1"
                                form="formUsuarios_<%= usuarios[i].id %>">Modificar</button>
                              <form action="/user/<%= usuarios[i].id %>/delete" method="POST"
                                onsubmit="return confirm('¿Estás seguro de que quieres eliminar este usuario?');"
                                style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                              </form>
                            </td>
                          </tr>
                          <% } %>
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="tab-pane fade" id="estadisticas" role="tabpanel">

                  <h3 class="mt-3">Concesionarios con más reservas</h3>
                  <% if (topConcesionarios && topConcesionarios.length> 0) { %>
                    <ul class="list-group mb-4">
                      <% topConcesionarios.forEach(c=> { %>
                        <li class="list-group-item d-flex justify-content-between">
                          <span><strong>
                              <%= c.nombre %>
                            </strong></span>
                          <span class="badge bg-primary">
                            <%= c.total_reservas %> reservas
                          </span>
                        </li>
                        <% }) %>
                    </ul>
                    <% } else { %>
                      <p>No hay datos disponibles.</p>
                      <% } %>


                        <h3 class="mt-3">Vehículos con más reservas</h3>
                        <% if (topVehiculos && topVehiculos.length> 0) { %>
                          <ul class="list-group">
                            <% topVehiculos.forEach(v=> { %>
                              <li class="list-group-item d-flex justify-content-between">
                                <span>
                                  <strong>
                                    <%= v.marca %>
                                      <%= v.modelo %>
                                  </strong>
                                  (<%= v.matricula %>)
                                </span>
                                <span class="badge bg-success">
                                  <%= v.total_reservas %> reservas
                                </span>
                              </li>
                              <% }) %>
                          </ul>
                          <% } else { %>
                            <p>No hay datos disponibles.</p>
                            <% } %>

                </div>
              </div>
    </main>

    <%- include("partials/footer") %>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
      <script src="/js/client.js"></script>
</body>

</html>