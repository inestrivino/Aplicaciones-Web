<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Catálogo EcoMóvil</title>
    <meta name="description"
        content="EcoMóvil es una empresa de vehículos eléctricos disponibles para préstamo. Esta página permite a nuestros empleados gestionar nuestra flota." />
    <meta name="keywords"
        content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil, soluciones de transporte, movilidad verde" />
    <meta name="author" content="EcoMóvil" />
    <meta name="robots" content="index, follow" />
    <link rel="icon" href="/img/Logo.svg" type="image/x-icon" />

    <!-- Enlaces a las hojas de estilo -->
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="/https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>
    <!-- NAVBAR -->
    <%- include('partials/header', { user: user, concesionarios: concesionarios }) %>

        <main class="container" aria-label="Contenido principal de la página">
            <h1>Catálogo de vehículos</h1>

            <!-- Filtro de Vehículos y Catálogo -->
            <div class="row">
                <!-- Columna de filtros (izquierda) -->
                <div class="col-12 col-lg-3">
                    <div class="filter-container">
                        <h3>Filtrar Vehículos</h3>
                        <form action="/vehiculos/filterVehiculos" method="get" id="filtrosForm">
                            <div class="mb-3">
                                <label for="marcaSelect" class="form-label"><strong>Marca</strong></label>
                                <select id="marcaSelect" class="form-select" name="marcaSelect">
                                    <option selected value="">Sin filtro</option>
                                    <% if (marcas && marcas.length> 0) { %>
                                        <% marcas.forEach(m=> { %>
                                            <option value="<%= m.marca %>">
                                                <%= m.marca %>
                                            </option>
                                            <% }) %>
                                                <% } %>
                                </select>
                            </div>

                            <!-- Filtro por Autonomía -->
                            <div class="mb-3">
                                <label for="autonomiaSelect" class="form-label"><strong>Autonomía (km)</strong></label>
                                <select id="autonomiaSelect" name="autonomiaSelect" class="form-select">
                                    <option selected value="">Sin filtro</option>
                                    <option value="500">Más de 500 km</option>
                                    <option value="400">400 - 499 km</option>
                                    <option value="300">300 - 399 km</option>
                                    <option value="200">Menos de 300 km</option>
                                </select>
                            </div>

                            <!-- Filtro por Concesionario -->
                            <div class="mb-3">
                                <label for="concesionarioSelect"
                                    class="form-label"><strong>Concesionario</strong></label>
                                <select id="concesionarioSelect" name="concesionarioSelect" class="form-select">
                                    <option selected value="">Sin filtro</option>
                                    <% if (concesionarios && concesionarios.length> 0) { %>
                                        <% concesionarios.forEach(c=> { %>
                                            <option value="<%= c.id %>">
                                                <%= c.nombre %>
                                            </option>
                                            <% }) %>
                                                <% } %>
                                </select>
                            </div>

                            <!-- Filtro por Ciudad -->
                            <div class="mb-3">
                                <label for="ciudadSelect" class="form-label"><strong>Ciudad</strong></label>
                                <select id="ciudadSelect" name="ciudadSelect" class="form-select">
                                    <option selected value="">Sin filtro</option>
                                    <% if (ciudades && ciudades.length> 0) { %>
                                        <% ciudades.forEach(c=> { %>
                                            <option value="<%= c.ciudad %>">
                                                <%= c.ciudad %>
                                            </option>
                                            <% }) %>
                                                <% } %>
                                </select>
                            </div>

                            <!-- Filtro por Plazas -->
                            <div class="mb-3">
                                <label for="plazasSelect" class="form-label"><strong>Plazas</strong></label>
                                <select id="plazasSelect" name="plazasSelect" class="form-select">
                                    <option selected value="">Sin filtro</option>
                                    <% if (plazas && plazas.length> 0) { %>
                                        <% plazas.forEach(p=> { %>
                                            <option value="<%= p.plazas %>">
                                                <%= p.plazas %>
                                            </option>
                                            <% }) %>
                                                <% } %>
                                </select>
                            </div>

                            <!-- Filtro por Color -->
                            <div class="mb-3">
                                <label for="colorSelect" class="form-label"><strong>Color</strong></label>
                                <select id="colorSelect" name="colorSelect" class="form-select">
                                    <option value="" selected>Sin filtro</option>
                                    <% if (colores && colores.length> 0) { %>
                                        <% colores.forEach(c=> { %>
                                            <option value="<%= c.color %>">
                                                <%= c.color %>
                                            </option>
                                            <% }) %>
                                                <% } %>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary">Aplicar filtros</button>
                        </form>
                    </div>
                </div>

                <!-- Columna de vehículos (derecha) -->
                <div class="col-md-9">
                    <div class="row row-cols-1 row-cols-lg-3 g-4" id="vehiculosContainer">
                        <% if (vehiculos && vehiculos.length> 0) { %>
                            <% vehiculos.forEach(v=> {
                                // Buscar el nombre del concesionario correspondiente
                                const concesionario = concesionarios.find(c => c.id === v.id_concesionario);
                                const nombreConcesionario = concesionario ? concesionario.nombre : 'N/D';
                                %>
                                <div class="col">
                                    <div class="card h-100 d-flex flex-column"
                                        style="max-width: 350px; margin: 0 auto;">
                                        <!-- Image container with fixed height -->
                                        <div style="height: 200px; overflow: hidden;">
                                            <img src="<%= v.imagen || '/img/default-car.jpg' %>"
                                                class="card-img-top w-100 h-100"
                                                alt="Imagen de <%= v.marca %> <%= v.modelo %>"
                                                style="object-fit: cover;">
                                        </div>

                                        <div class="card-body">
                                            <h5 class="card-title">
                                                <strong>Marca:</strong>
                                                <%= v.marca %><br>
                                                    <strong>Modelo:</strong>
                                                    <%= v.modelo %>
                                            </h5>
                                            <p class="card-text">
                                                <strong>Matrícula:</strong>
                                                <%= v.matricula %><br>
                                                    <strong>Plazas:</strong>
                                                    <%= v.plazas %><br>
                                                        <strong>Autonomía:</strong>
                                                        <%= v.autonomia %> km<br>
                                                            <strong>Color:</strong>
                                                            <%= v.color %><br>
                                                                <strong>Concesionario:</strong>
                                                                <%= nombreConcesionario %>
                                            </p>
                                        </div>

                                        <!-- Botón de reservar -->
                                        <div class="card-footer bg-transparent border-0 mt-auto">
                                            <button class="btn btn-primary w-100"
                                                onclick="reserveCar('<%= v.matricula %>')">
                                                Reservar
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div class="col">
                                            <p>No se encontraron vehículos con los filtros aplicados.</p>
                                        </div>
                                        <% } %>
                    </div>
                </div>
            </div>
        </main>

        <!-- FOOTER -->
        <%- include("partials/footer") %>

            <!-- Script de Bootstrap -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <!-- Scripts personalizados -->
            <script src="/js/client.js"></script>
</body>

</html>