<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Catálogo EcoMóvil</title>
    <meta name="description"
        content="EcoMóvil es una empresa de vehículos eléctricos disponibles para préstamo. Esta página permite a nuestros empleados gestionar nuestra flota." />
    <meta name="keywords"
        content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil, soluciones de transporte, movilidad verde" />
    <meta name="author" content="EcoMóvil" />
    <meta name="robots" content="index, follow" />
    <link rel="icon" href="img/Logo.svg" type="image/x-icon" />

    <!-- Enlaces a las hojas de estilo -->
    <link rel="stylesheet" href="css/bootstrap.min.css" />
    <link rel="stylesheet" href="css/styles.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>
    <!-- NAVBAR -->
    <%- include("header") %>

    <!-- MODAL DE AJUSTES -->
    <div class="modal fade" id="ajustesModal" tabindex="-1" aria-labelledby="ajustesModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="ajustesModalLabel">Ajustes</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <div class="modal-body">

                    <!-- Sección: Idioma -->
                    <section>
                        <h6>Idioma</h6>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="dropdownIdioma"
                                data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="idiomaSeleccionado">Español</span>
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="dropdownIdioma">
                                <li><a class="dropdown-item" href="#" data-lang="es">Español</a></li>
                                <li><a class="dropdown-item" href="#" data-lang="en">English</a></li>
                            </ul>
                        </div>
                    </section>

                    <!-- Sección: Tema -->
                    <section>
                        <h6>Tema visual</h6>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="tema" id="temaClaro" value="claro"
                                checked>
                            <label class="form-check-label" for="temaClaro">Claro</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="tema" id="temaOscuro" value="oscuro">
                            <label class="form-check-label" for="temaOscuro">Oscuro</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="tema" id="temaAltoContraste"
                                value="alto-contraste">
                            <label class="form-check-label" for="temaAltoContraste">Alto contraste</label>
                        </div>
                    </section>

                    <!-- Sección: Tamaño de letra -->
                    <section>
                        <h6>Tamaño de letra</h6>
                        <label for="fontSizeRange" class="form-label small text-muted">
                            Selecciona el tamaño del texto
                        </label>
                        <input type="range" class="form-range" id="fontSizeRange" min="1" max="1.4" step="0.05"
                            value="1.2">
                        <p>Tamaño actual: <span id="fontSizeValue">1.2rem</span></p>
                    </section>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="guardarCambios">Guardar cambios</button>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL DE USUARIO -->
    <div class="modal fade" id="usuarioModal" tabindex="-1" aria-labelledby="usuarioModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="usuarioModalLabel">Mi cuenta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <p>Aún no has iniciado sesión.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" class="btn btn-primary">Guardar cambios</button>
                </div>
            </div>
        </div>
    </div>
    <main class="container mt-5 pt-5" aria-label="Contenido principal de la página">
        <h1>Catálogo de vehículos</h1>

        <!-- Filtro de Vehículos y Catálogo -->
        <div class="row">
            <!-- Columna de filtros (izquierda) -->
            <div class="col-12 col-lg-3">
                <div class="filter-container">
                    <h3>Filtrar Vehículos</h3>
                    <form>
                        <!-- Filtro por Marca -->
                        <div class="mb-3">
                            <label for="marcaSelect" class="form-label">Marca</label>
                            <select id="marcaSelect" class="form-select">
                                <option value="">Seleccione una marca</option>
                                <option value="Tesla">Tesla</option>
                                <option value="Renault">Renault</option>
                                <option value="Nissan">Nissan</option>
                            </select>
                        </div>

                        <!-- Filtro por Autonomía -->
                        <div class="mb-3">
                            <label for="autonomiaSelect" class="form-label">Autonomía (km)</label>
                            <select id="autonomiaSelect" class="form-select">
                                <option value="">Seleccione autonomía</option>
                                <option value="500">Más de 500 km</option>
                                <option value="400">400 - 499 km</option>
                                <option value="300">300 - 399 km</option>
                                <option value="200">Menos de 300 km</option>
                            </select>
                        </div>

                        <!-- Filtro por Tipo -->
                        <div class="mb-3">
                            <label class="form-label">Tipo de vehículo</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="eléctrico" id="tipoElectrico">
                                <label class="form-check-label" for="tipoElectrico">Eléctrico</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="híbrido" id="tipoHibrido">
                                <label class="form-check-label" for="tipoHibrido">Híbrido</label>
                            </div>
                        </div>

                        <!-- Botón de aplicar filtro -->
                        <button type="submit" class="btn btn-primary filter-btn">Aplicar filtros</button>
                    </form>
                </div>
            </div>

            <!-- Columna de vehículos (derecha) -->
            <div class="col-md-9">
                <div class="row row-cols-1 row-cols-lg-3 g-4">
                    <% for (let i = 0; i < vehiculos.length; i++) { %>
                        <div class="col">
                            <div class="card h-100">
                                <img src="<%= vehiculos[i].imagen %>" class="card-img-top img-fluid" alt="<%= vehiculos[i].nombre %>"
                                    style="height: 200px; object-fit: cover;">
                                <div class="card-body">
                                    <h5 class="card-title"> <%= vehiculos[i].nombre %> </h5>
                                    <p class="card-text">Matrícula: <%= vehiculos[i].matricula %></p>
                                    <p class="card-text">Autonomía: <%= vehiculos[i].autonomia %></p>
                                    <div class="d-flex justify-content-center">
                                        <button class="btn btn-primary" onclick="reserveCar('1234ABC')">Reservar</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <%- include("footer") %>

    <!-- Script de Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/client.js"></script>

</body>

</html>