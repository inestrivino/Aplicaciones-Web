<!DOCTYPE html>
<html lang="es" data-theme="default">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Catálogo EcoMóvil</title>
    <meta name="description"
        content="EcoMóvil es una empresa de vehículos eléctricos disponibles para préstamo. Esta página permite a nuestros empleados gestionar nuestra flota." />
    <meta name="keywords"
        content="transporte ecológico, vehículos eléctricos, movilidad sostenible, EcoMóvil, soluciones de transporte, movilidad verde" />
    <meta name="author" content="EcoMóvil" />
    <meta name="robots" content="index, follow" />
    <link rel="icon" href="img/Logo.svg" type="image/x-icon" />

    <!-- Enlaces a las hojas de estilo -->
    <link rel="stylesheet" href="css/bootstrap.min.css" />
    <link rel="stylesheet" href="css/styles.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>
    <!-- NAVBAR -->
    <%- include('partials/header', { user: user }) %>

        <main class="container mt-5 pt-5" aria-label="Contenido principal de la página">
            <h1>Catálogo de vehículos</h1>

            <!-- Filtro de Vehículos y Catálogo -->
            <div class="row">
                <!-- Columna de filtros (izquierda) -->
                <div class="col-12 col-lg-3">
                    <div class="filter-container">
                        <h3>Filtrar Vehículos</h3>
                        <form>
                            <!-- Filtro por Marca -->
                            <div class="mb-3">
                                <label for="marcaSelect" class="form-label">Marca</label>
                                <select id="marcaSelect" class="form-select">
                                    <option value="">Seleccione una marca</option>
                                    <option value="Tesla">Tesla</option>
                                    <option value="Renault">Renault</option>
                                    <option value="Nissan">Nissan</option>
                                </select>
                            </div>

                            <!-- Filtro por Autonomía -->
                            <div class="mb-3">
                                <label for="autonomiaSelect" class="form-label">Autonomía (km)</label>
                                <select id="autonomiaSelect" class="form-select">
                                    <option value="">Seleccione autonomía</option>
                                    <option value="500">Más de 500 km</option>
                                    <option value="400">400 - 499 km</option>
                                    <option value="300">300 - 399 km</option>
                                    <option value="200">Menos de 300 km</option>
                                </select>
                            </div>

                            <!-- Filtro por Concesionario -->
                            <div class="mb-3">
                                <label for="concesionarioSelect" class="form-label">Concesionario</label>
                                <select id="concesionarioSelect" class="form-select">
                                    <option value="">Seleccione un concesionario</option>
                                    <option value="Concesionario1">Concesionario 1</option>
                                    <option value="Concesionario2">Concesionario 2</option>
                                </select>
                            </div>

                            <!-- Filtro por Color -->
                            <div class="mb-3">
                                <label for="colorSelect" class="form-label">Color</label>
                                <select id="colorSelect" class="form-select">
                                    <option value="">Seleccione un color</option>
                                    <option value="rojo">Rojo</option>
                                    <option value="azul">Azul</option>
                                    <option value="negro">Negro</option>
                                    <option value="blanco">Blanco</option>
                                    <option value="gris">Gris</option>
                                    <option value="verde">Verde</option>
                                </select>
                            </div>

                            <!-- Filtro por Tipo -->
                            <div class="mb-3">
                                <label class="form-label">Tipo de vehículo</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="eléctrico"
                                        id="tipoElectrico">
                                    <label class="form-check-label" for="tipoElectrico">Eléctrico</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="híbrido" id="tipoHibrido">
                                    <label class="form-check-label" for="tipoHibrido">Híbrido</label>
                                </div>
                            </div>

                            <!-- Botón de aplicar filtro -->
                            <button type="submit" class="btn btn-primary filter-btn">Aplicar filtros</button>
                        </form>
                    </div>
                </div>

                <!-- Columna de vehículos (derecha) -->
                <div class="col-md-9">
                    <div class="row row-cols-1 row-cols-lg-3 g-4">
                        <% for (let i=0; i < vehiculos.length; i++) { %>
                            <div class="col">
                                <div class="card h-100">
                                    <img src="<%= vehiculos[i].imagen %>" class="card-img-top img-fluid"
                                        alt="<%= vehiculos[i].nombre %>" style="height: 200px; object-fit: cover;">
                                    <div class="card-body">
                                        <h5 class="card-title">
                                            <%= vehiculos[i].nombre %>
                                        </h5>
                                        <!-- Detalles del vehículo -->
                                        <ul class="list-unstyled">
                                            <li><strong>Matrícula:</strong>
                                                <%= vehiculos[i].matricula %>
                                            </li>
                                            <li><strong>Autonomía:</strong>
                                                <%= vehiculos[i].autonomia %> km
                                            </li>
                                            <li><strong>Plazas:</strong>
                                                <%= vehiculos[i].plazas %>
                                            </li>
                                            <li><strong>Concesionario:</strong>
                                                <%= vehiculos[i].concesionario %>
                                            </li>
                                        </ul>
                                        <div class="d-flex justify-content-center">
                                            <button class="btn btn-primary"
                                                onclick="reserveCar('1234ABC')">Reservar</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>
        </main>

        <!-- FOOTER -->
        <%- include("partials/footer") %>

        <!-- Script de Bootstrap -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="/js/client.js"></script>

</body>

</html>